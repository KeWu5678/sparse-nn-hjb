# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so

# ---- Packaging / build ----
build/
dist/
*.egg
*.egg-info/
.eggs/

# ---- Virtual environments ----
.env
.venv/
env/
venv/

# ---- Tests / coverage ----
.pytest_cache/
.cache
.coverage
.coverage.*
coverage.xml
htmlcov/
.hypothesis/

# ---- Type checking ----
.mypy_cache/

# ---- Jupyter ----
.ipynb_checkpoints/

# ---- Logs ----
*.log
multirun/

# ---- OS junk ----
.DS_Store
Thumbs.db

# ---- Editor / AI tools  (.vscode/ is intentionally tracked) ----
.idea/
.claude/
.cursor/

# ---- MLflow (local tracking store) ----
mlruns/
mlflow.db
mlflow.db-journal

# ---- Project artifacts: kept locally, not version-controlled ----
outdated/
rawdata/
reference/
plan.md

# ---- autoresearch outputs (scoreboards + per-run JSON/logs) ----
autoresearch/results.tsv
autoresearch/runs/
autoresearch/**/results.tsv
autoresearch/**/runs/
autoresearch/**/*.json
autoresearch/**/*.log

# ---- Private research notes (theory program) ----
docs/research/

# ---- Untracked locally: analysis scripts and thesis source ----
experiments/**/analysis.py

# ---- Terraform (deploy/terraform/) — .terraform.lock.hcl stays tracked ----
deploy/terraform/.terraform/
deploy/terraform/*.tfstate
deploy/terraform/*.tfstate.*
deploy/terraform/*.tfvars
deploy/terraform/*.tfvars.json
!deploy/terraform/example.tfvars

# ---- papar/ (LaTeX thesis): only the compiled PDF + main source are tracked ----
papar/*
!papar/Mthesis.pdf
!papar/Mthesis.tex
!papar/draft/
papar/draft/*
!papar/draft/PROOF_NARROW-CONVERGENCE.tex
!papar/draft/PROOF_NARROW-CONVERGENCE.pdf

# domain-language notes are local working docs
CONTEXT.md
